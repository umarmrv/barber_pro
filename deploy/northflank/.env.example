APP_ENV=prod

BOT_TOKEN=CHANGE_ME
WEBHOOK_SECRET=CHANGE_ME_STRONG_SECRET
WEBHOOK_URL=https://your-service.northflank.app/telegram/webhook
ADMIN_API_SECRET=CHANGE_ME_ADMIN_SECRET

POSTGRES_DSN=postgresql+asyncpg://user:password@postgres-host:5432/barber
POSTGRES_DSN_SYNC=postgresql://user:password@postgres-host:5432/barber
REDIS_DSN=redis://redis-host:6379/0

SALON_TIMEZONE=Asia/Tashkent
DEFAULT_REGION=TJ
DEFAULT_LOCALE=ru

ADMIN_IDS=
ADMIN_GROUP_ID=

BOOKING_MIN_LEAD_HOURS=1
BOOKING_MAX_DAYS=14
CANCEL_MIN_LEAD_HOURS=2

REMINDER_POLL_SECONDS=30
IDEMPOTENCY_TTL_SECONDS=86400
DRAFT_TTL_SECONDS=900

AUTO_CREATE_SCHEMA=false
SKIP_BOT_API_CALLS=false

# For the internal bot worker, it is recommended to override:
# SKIP_BOT_API_CALLS=true
